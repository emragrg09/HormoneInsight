# Environment configuration for Hormone Insight
#
# When mock mode is enabled the frontend uses realistic mock responses and
# never contacts a backend. When you set VITE_USE_MOCK_API=false, the shared
# API service calls the FastAPI backend at VITE_API_BASE_URL.

VITE_USE_MOCK_API=true
VITE_API_BASE_URL=http://localhost:8000
